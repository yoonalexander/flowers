{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/flowers/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/flowers", "destination": "/index.html" },
    { "source": "/flowers/:path*", "destination": "/index.html" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
